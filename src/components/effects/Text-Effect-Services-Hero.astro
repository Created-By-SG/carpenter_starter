---
interface Props {
  phrases?: string[];
}

const { phrases = ['paint Gold Coast homes'] } = Astro.props;
const uid = `text-typewriter-${Math.random().toString(36).slice(2, 9)}`;
---

<span class="text-typewriter" id={uid} data-phrases={JSON.stringify(phrases)}></span><span class="text-typewriter__cursor" aria-hidden="true">|</span>

<style>
  .text-typewriter__cursor {
    color: var(--hero-highlight-text, #5eead4);
    font-weight: 300;
    animation: text-typewriter-blink 1s step-end infinite;
  }

  @keyframes text-typewriter-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .text-typewriter__cursor {
      animation: none;
    }
  }
</style>

<script is:inline define:vars={{ uid }}>
  (function () {
    var el = document.getElementById(uid);
    if (!el) return;

    var phrases = JSON.parse(el.dataset.phrases || '[]');
    if (!phrases.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = phrases[0];
      return;
    }

    var phraseIndex = 0;
    var charIndex = 0;
    var deleting = false;

    function tick() {
      var current = phrases[phraseIndex] || '';

      if (deleting) {
        el.textContent = current.substring(0, charIndex--);
        if (charIndex < 0) {
          deleting = false;
          charIndex = 0;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          setTimeout(tick, 420);
          return;
        }
        setTimeout(tick, 42);
        return;
      }

      el.textContent = current.substring(0, charIndex++);
      if (charIndex > current.length) {
        deleting = true;
        setTimeout(tick, 1800);
        return;
      }
      setTimeout(tick, 88);
    }

    var started = false;
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting && !started) {
          started = true;
          observer.disconnect();
          setTimeout(tick, 350);
        }
      });
    }, { threshold: 0.1 });

    observer.observe(el);
  })();
</script>
