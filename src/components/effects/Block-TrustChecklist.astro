---
interface Props {
  items?: string[];
}

const { items = [] } = Astro.props;
const uid = `trust-checklist-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="trust-checklist" id={uid}>
  <ul class="trust-checklist__list">
    {items.map((item, index) => (
      <li class="trust-checklist__item" style={`--item-index:${index}`}>
        <span class="trust-checklist__icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .trust-checklist {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .trust-checklist__list {
    display: inline-flex;
    flex-direction: column;
    gap: 14px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .trust-checklist__item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: var(--checklist-item-text);
    font-size: var(--font-size-body);
    line-height: var(--line-height-body);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.45s ease, transform 0.45s ease;
    transition-delay: calc(var(--item-index, 0) * 65ms);
    text-align: left;
  }

  .trust-checklist.in-view .trust-checklist__item {
    opacity: 1;
    transform: translateY(0);
  }

  .trust-checklist__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 24px;
    height: 24px;
    margin-top: 2px;
    border-radius: 999px;
    background: var(--checklist-icon-bg);
    color: var(--checklist-icon-text);
  }

  @media (min-width: 744px) {
    .trust-checklist__item {
      align-items: center;
      text-align: center;
    }

    .trust-checklist__icon {
      margin-top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-checklist__item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script is:inline define:vars={{ uid }}>
  (function () {
    var root = document.getElementById(uid);
    if (!root) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      root.classList.add('in-view');
      return;
    }
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          root.classList.add('in-view');
          observer.disconnect();
        }
      });
    }, { threshold: 0.1 });
    observer.observe(root);
  })();
</script>
