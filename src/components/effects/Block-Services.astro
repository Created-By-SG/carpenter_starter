---
interface ServiceCard {
  title: string;
  description: string;
  href: string;
}

interface Props {
  services?: ServiceCard[];
}

const { services = [] } = Astro.props;
const uid = `services-wave-grid-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="services-wave" id={uid}>
  <div class="services-wave__grid">
    <svg class="services-wave__lines" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"></svg>
    {services.map((service, index) => (
      <a class="services-wave__card" href={service.href} data-index={index}>
        <span class="services-wave__shine" aria-hidden="true"></span>
        <h3 class="services-wave__title">{service.title}</h3>
        <p class="services-wave__body">{service.description}</p>
      </a>
    ))}
  </div>
</div>

<style>
  .services-wave {
    width: 100%;
  }

  .services-wave__grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    width: 100%;
    max-width: 900px;
    margin: 24px auto 0;
  }

  @media (min-width: 744px) {
    .services-wave__grid {
      gap: var(--s-gap, 16px);
    }
  }

  .services-wave__lines {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .services-wave.in-view .services-wave__lines {
    opacity: 0.16;
  }

  .services-wave__lines :global(line) {
    stroke: var(--hero-highlight-text, #5eead4);
    stroke-width: 1;
    stroke-dasharray: 3 5;
    opacity: 0;
    animation: services-wave-line-draw 0.9s ease forwards;
  }

  .services-wave__card {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 132px;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding: 16px 10px;
    border: 1px solid color-mix(in srgb, var(--hero-highlight-text, #5eead4) 28%, transparent);
    border-radius: 10px;
    background: color-mix(in srgb, var(--card-bg, rgba(255,255,255,0.06)) 82%, transparent);
    box-shadow: var(--step-card-shadow);
    text-align: center;
    text-decoration: none;
    opacity: 0.15;
    transform: translateY(20px) scale(0.96);
    transition:
      opacity 0.5s ease,
      transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      background 0.3s ease;
  }

  .services-wave__card:last-of-type:nth-of-type(odd) {
    grid-column: 1 / -1;
    width: calc(50% - 5px);
    justify-self: center;
  }

  @media (min-width: 744px) {
    .services-wave__card {
      min-height: 148px;
      padding: 22px 18px;
    }

    .services-wave__card:last-of-type:nth-of-type(odd) {
      width: calc(50% - var(--s-gap, 16px) / 2);
    }
  }

  .services-wave__card::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 86px;
    height: 86px;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--hero-highlight-text, #5eead4) 28%, transparent) 0%, transparent 72%);
    filter: blur(28px);
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -50%);
    transition: opacity 1.4s ease;
  }

  .services-wave__shine {
    position: absolute;
    inset: -40% auto auto -60%;
    width: 55%;
    height: 180%;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--hero-highlight-text, #5eead4) 16%, transparent), transparent);
    opacity: 0;
    transform: rotate(20deg);
    pointer-events: none;
  }

  .services-wave__card.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .services-wave__card.wave-active {
    border-color: color-mix(in srgb, var(--hero-highlight-text, #5eead4) 58%, transparent);
    background: color-mix(in srgb, var(--card-bg, rgba(255,255,255,0.06)) 72%, var(--hero-highlight-text, #5eead4) 8%);
    box-shadow:
      0 0 22px color-mix(in srgb, var(--hero-highlight-text, #5eead4) 24%, transparent),
      inset 0 0 12px color-mix(in srgb, var(--hero-highlight-text, #5eead4) 13%, transparent),
      var(--step-card-shadow);
    transform: translateY(-2px) scale(1.02);
  }

  .services-wave__card.wave-active::before {
    opacity: 0.62;
  }

  .services-wave__card.wave-active .services-wave__shine {
    animation: services-wave-shine 1.35s ease forwards;
  }

  .services-wave__card:hover,
  .services-wave__card:focus-visible {
    border-color: color-mix(in srgb, var(--hero-highlight-text, #5eead4) 58%, transparent);
    transform: translateY(-3px);
  }

  .services-wave__card.neighbor-hover {
    border-color: color-mix(in srgb, var(--hero-highlight-text, #5eead4) 32%, transparent);
    transform: translateY(-1px);
  }

  .services-wave__title {
    color: var(--hero-highlight-text);
    font-size: 0.84rem;
    font-weight: var(--font-weight-bold);
    line-height: 1.22;
    margin: 0 0 8px;
    opacity: 0;
    transform: translateY(8px);
    overflow-wrap: anywhere;
  }

  @media (min-width: 744px) {
    .services-wave__title {
      font-size: var(--font-size-card-title);
      line-height: var(--line-height-section);
    }
  }

  .services-wave__card.is-visible .services-wave__title {
    animation: services-wave-title-slide 0.4s ease 0.08s forwards;
  }

  .services-wave__body {
    color: var(--card-body-text);
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold);
    line-height: 1.42;
    margin: 0;
    opacity: 0;
    transform: translateY(6px);
  }

  @media (min-width: 744px) {
    .services-wave__body {
      font-size: var(--font-size-body-small);
      line-height: var(--line-height-card);
    }
  }

  .services-wave__card.is-visible .services-wave__body {
    animation: services-wave-body-fade 0.45s ease 0.18s forwards;
  }

  @keyframes services-wave-title-slide {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes services-wave-body-fade {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes services-wave-line-draw {
    from { opacity: 0; stroke-dashoffset: 16; }
    to { opacity: 0.25; stroke-dashoffset: 0; }
  }

  @keyframes services-wave-shine {
    0% { opacity: 0; transform: translateX(0) rotate(20deg); }
    25% { opacity: 0.65; }
    100% { opacity: 0; transform: translateX(360%) rotate(20deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-wave__card,
    .services-wave__title,
    .services-wave__body {
      animation: none !important;
      opacity: 1;
      transform: none;
      transition: none;
    }

    .services-wave__lines,
    .services-wave__shine {
      display: none;
    }
  }
</style>

<script is:inline define:vars={{ uid }}>
  (function () {
    var root = document.getElementById(uid);
    if (!root) return;

    var grid = root.querySelector('.services-wave__grid');
    var linesSvg = root.querySelector('.services-wave__lines');
    var cards = Array.prototype.slice.call(root.querySelectorAll('.services-wave__card'));
    var hasTriggered = false;
    var waveTimeout = null;
    var currentWaveIndex = 0;
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function getCols() {
      if (!grid) return 1;
      var style = window.getComputedStyle(grid);
      var cols = style.gridTemplateColumns.trim().split(' ').filter(Boolean);
      return cols.length || 1;
    }

    function getStaggerDelay(index, cols) {
      var row = Math.floor(index / cols);
      var col = index % cols;
      return (row + col) * 100;
    }

    function revealBlock() {
      if (hasTriggered) return;
      hasTriggered = true;
      root.classList.add('in-view');

      if (reducedMotion) {
        cards.forEach(function (card) {
          card.classList.add('is-visible');
        });
        return;
      }

      var cols = getCols();
      cards.forEach(function (card, index) {
        setTimeout(function () {
          card.classList.add('is-visible');
        }, getStaggerDelay(index, cols));
      });

      setTimeout(drawConnections, 120);
      setTimeout(startAmbientWave, 1500);
    }

    function startAmbientWave() {
      if (!cards.length || reducedMotion) return;

      cards.forEach(function (card) {
        card.classList.remove('wave-active');
      });
      cards[currentWaveIndex].classList.add('wave-active');
      currentWaveIndex = (currentWaveIndex + 1) % cards.length;
      waveTimeout = setTimeout(startAmbientWave, 1550);
    }

    function getCardPosition(card) {
      var cols = getCols();
      var index = Number(card.dataset.index || 0);
      return { row: Math.floor(index / cols), col: index % cols, cols: cols };
    }

    function getNeighbors(card) {
      var pos = getCardPosition(card);
      return cards.filter(function (other) {
        if (other === card) return false;
        var otherPos = getCardPosition(other);
        return Math.abs(pos.row - otherPos.row) + Math.abs(pos.col - otherPos.col) === 1;
      });
    }

    function drawConnections() {
      if (!grid || !linesSvg || reducedMotion) return;

      var gridRect = grid.getBoundingClientRect();
      var cols = getCols();
      linesSvg.setAttribute('viewBox', '0 0 ' + gridRect.width + ' ' + gridRect.height);
      linesSvg.innerHTML = '';

      cards.forEach(function (card, index) {
        var cardRect = card.getBoundingClientRect();
        var cx = cardRect.left - gridRect.left + cardRect.width / 2;
        var cy = cardRect.top - gridRect.top + cardRect.height / 2;
        var pos = getCardPosition(card);

        if (pos.col < pos.cols - 1 && cards[index + 1]) {
          appendLine(cx, cy, cards[index + 1], gridRect, (pos.row + pos.col) * 0.1 + 0.35);
        }

        if (cards[index + cols]) {
          appendLine(cx, cy, cards[index + cols], gridRect, (pos.row + pos.col) * 0.1 + 0.55);
        }
      });
    }

    function appendLine(x1, y1, targetCard, gridRect, delay) {
      var targetRect = targetCard.getBoundingClientRect();
      var x2 = targetRect.left - gridRect.left + targetRect.width / 2;
      var y2 = targetRect.top - gridRect.top + targetRect.height / 2;
      var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      line.setAttribute('x1', x1);
      line.setAttribute('y1', y1);
      line.setAttribute('x2', x2);
      line.setAttribute('y2', y2);
      line.style.animationDelay = delay + 's';
      linesSvg.appendChild(line);
    }

    cards.forEach(function (card) {
      card.addEventListener('mouseenter', function () {
        getNeighbors(card).forEach(function (neighbor) {
          neighbor.classList.add('neighbor-hover');
        });
      });

      card.addEventListener('mouseleave', function () {
        getNeighbors(card).forEach(function (neighbor) {
          neighbor.classList.remove('neighbor-hover');
        });
      });
    });

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          revealBlock();
          observer.disconnect();
        }
      });
    }, { threshold: 0.1 });

    observer.observe(root);

    var resizeTimer = null;
    window.addEventListener('resize', function () {
      if (!hasTriggered) return;
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(drawConnections, 150);
    });

    window.addEventListener('pagehide', function () {
      if (waveTimeout) window.clearTimeout(waveTimeout);
    });
  })();
</script>
