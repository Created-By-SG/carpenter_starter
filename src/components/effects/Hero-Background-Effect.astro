---
interface Props {
  image?: string;
  imageAlt?: string;
}

const {
  image = '/images/hero.webp',
  imageAlt = 'Premium carpentry project',
} = Astro.props;

---

<div class="hero-background-effect" aria-hidden="true">
  <img class="hero-background-effect__image" src={image} alt={imageAlt} loading="eager" fetchpriority="high" />
  <div class="hero-background-effect__grade"></div>
  <div class="hero-background-effect__atmosphere"></div>
</div>

<style>
  .hero-background-effect,
  .hero-background-effect__image,
  .hero-background-effect__grade,
  .hero-background-effect__atmosphere {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-background-effect {
    z-index: 0;
    overflow: hidden;
    background: var(--navy);
  }

  .hero-background-effect__image {
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.72;
    transform: scale(1);
    filter: saturate(0.86) contrast(1.02);
    animation: heroKenBurns 22s ease-in-out infinite alternate;
  }

  .hero-background-effect__grade {
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0.36) 72%, rgba(255, 255, 255, 0.58) 100%),
      linear-gradient(90deg, rgba(26, 39, 68, 0.34), rgba(0, 102, 153, 0.22));
  }

  .hero-background-effect__atmosphere {
    z-index: 2;
    background:
      radial-gradient(circle at 18% 76%, rgba(255, 255, 255, 0.38), transparent 34%),
      radial-gradient(circle at 86% 24%, rgba(255, 255, 255, 0.22), transparent 28%);
    filter: blur(18px);
    opacity: 0.78;
    animation: heroAtmosphereDrift 14s ease-in-out infinite alternate;
  }

  @keyframes heroKenBurns {
    from { transform: scale(1) translate(0, 0); }
    to { transform: scale(1.08) translate(-1%, -1%); }
  }

  @keyframes heroAtmosphereDrift {
    from { transform: translate3d(-1%, 1%, 0) scale(1); }
    to { transform: translate3d(1%, -1%, 0) scale(1.06); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-background-effect__image,
    .hero-background-effect__atmosphere {
      animation: none;
    }
  }
</style>
