---
interface Props { items: string[]; }
const { items } = Astro.props;
const icons = [
  '<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 20h16"/><path d="M6 20V8l6-4 6 4v12"/><path d="M9 20v-6h6v6"/></svg>',
  '<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 3l7 4v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V7l7-4z"/><path d="M9 12l2 2 4-4"/></svg>',
  '<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 7h16"/><path d="M7 7v13"/><path d="M17 7v13"/><path d="M9 3h6l2 4H7l2-4z"/></svg>',
  '<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 21h18"/><path d="M6 21l12-12"/><path d="M9 6l3-3 3 3"/><path d="M12 3v12"/></svg>'
];
---
<section class="section why-us" id="about">
  <div class="container">
    <h2 class="section-title reveal-up">Why Work With Us</h2>
    <div class="features-grid reveal-up">
      {items.map((item, index) => (
        <div class="feature-box">
          <div class="feature-icon" set:html={icons[index % icons.length]} />
          <h4>{item}</h4>
        </div>
      ))}
    </div>
  </div>
</section>
