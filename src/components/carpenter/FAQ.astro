---
interface Props { faqs: Array<{ q: string; a: string }>; }
const { faqs } = Astro.props;
---
<section class="section faq" id="faq">
  <div class="container">
    <h2 class="section-title reveal-up">FAQ</h2>
    <div class="faq-list reveal-up">
      {faqs.map((faq) => (
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">{faq.q}<svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></button>
          <div class="faq-answer"><div class="faq-answer-inner">{faq.a}</div></div>
        </div>
      ))}
    </div>
  </div>
</section>
