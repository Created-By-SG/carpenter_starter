---
const icons = [
  '<svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M5 4h14v16H5z"/><path d="M8 8h8"/><path d="M8 12h6"/><path d="M8 16h5"/></svg>',
  '<svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M4 7h16"/><path d="M7 7v13"/><path d="M17 7v13"/><path d="M9 3h6l2 4H7l2-4z"/></svg>',
  '<svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 21h18"/><path d="M6 21V9l6-5 6 5v12"/><path d="M10 21v-6h4v6"/></svg>',
  '<svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M4 17l6-6 4 4 6-8"/><path d="M14 7h6v6"/></svg>',
  '<svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/><path d="M3 21h18"/></svg>'
];
---
<section class="section section-pad" id="process">
  <div class="container">
    <h2 class="section-title reveal-up">Our Process</h2>
    <p class="section-subtitle reveal-up">How We Work With You, Not Just For You</p>
    <div class="process-grid reveal-up">
      {['Initial Consultation','Detailed Quoting','Design & Planning','Construction','Final Walkthrough'].map((title, index) => (
        <div class="process-card">
          <div class="process-icon" set:html={icons[index]} />
          <h3>Step {index + 1}: {title}</h3>
          <p>{['We visit your home, listen to your ideas, and take measurements.','You receive a clear, itemised quote with options where possible.','We finalise designs, source materials, and prepare approvals if needed.','Our licensed team manages all aspects of the build from start to finish.','We check everything is finished to spec and answer any questions.'][index]}</p>
        </div>
      ))}
    </div>
  </div>
</section>
