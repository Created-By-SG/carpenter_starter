---
import business from '../data/business.json';
import servicesData from '../data/services.json';
import suburbsData from '../data/suburbs.json';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description = `${business.name} provides premium carpentry and renovations across the ${business.serviceArea}.`,
  canonicalUrl = `${business.domain}${Astro.url.pathname}`,
  ogImage = `${business.domain}/images/hero.webp`,
} = Astro.props;

const services = Object.entries(servicesData as Record<string, any>);
const suburbs = Object.entries(suburbsData as Record<string, any>);

const schemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: business.name,
  description,
  url: canonicalUrl,
  telephone: business.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: business.address,
    addressRegion: 'QLD',
    addressCountry: 'AU'
  },
  areaServed: business.serviceArea,
  priceRange: '$$$',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: business.rating,
    reviewCount: business.reviewCount
  }
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <script type="application/ld+json" set:html={schemaJson} />
  <slot name="head" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/carpenter.css" />
</head>
<body>
  <div class="scroll-bar" id="scrollBar"></div>
  <div class="demo-banner">
    Demo only. Not a real company. No services are offered.&nbsp;&nbsp;|&nbsp;&nbsp;<a href="https://www.balemo.com.au/showcase.html">Back to Showcase</a>
  </div>

  <div class="nav-outer" id="nav">
    <div class="nav-inner container">
      <a href="/" class="logo"><div class="logo-icon">{business.logoInitials}</div><span>{business.logoText}</span></a>
      <nav class="nav-links">
        <a href="/">Home</a>
        <div class="nav-dropdown">
          <a href="/services/" class="nav-dropdown-trigger">Services <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M6 9l6 6 6-6"/></svg></a>
          <div class="nav-dropdown-panel">
            <a href="/services/">All Services</a>
            {services.map(([serviceSlug, service]) => <a href={`/services/${serviceSlug}/`}>{service.shortTitle}</a>)}
          </div>
        </div>
        <div class="nav-dropdown">
          <a href="/suburbs/" class="nav-dropdown-trigger">Suburbs <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M6 9l6 6 6-6"/></svg></a>
          <div class="nav-dropdown-panel">
            <a href="/suburbs/">All Suburbs</a>
            {suburbs.map(([suburbSlug, suburb]) => <a href={`/suburbs/${suburbSlug}/`}>{suburb.pageMeta.title.replace('Carpenters ', '')}</a>)}
          </div>
        </div>
        <a href="/#about">About</a>
        <a href="/contact/">Contact</a>
      </nav>
      <div class="nav-actions">
        <button class="nav-btn nav-btn-text" onclick="openModal()"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Text</button>
        <a href={`tel:${business.phoneRaw}`} class="nav-btn nav-btn-call"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>Call</a>
      </div>
    </div>
  </div>

  <slot />

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo">{business.name}</div>
          <p>Premium carpentry and renovations across the {business.serviceArea}. Licensed and insured. Quality guaranteed.</p>
          <div class="footer-contact">
            <a href={`tel:${business.phoneRaw}`}>{business.phone}</a>
            <a href={`mailto:${business.email}`}>{business.email}</a>
          </div>
        </div>
        <div class="footer-col">
          <h3>Site</h3>
          <a href="/services/">Services</a>
          <a href="/suburbs/">Suburbs</a>
          <a href="/contact/">Contact</a>
          <a href="/legal/#terms">Terms Of Service</a>
          <a href="/legal/#privacy">Privacy Policy</a>
          <a href="/admin/">Admin</a>
          <a href="https://balemo.com.au">Built By Balemo</a>
        </div>
      </div>
      <p class="footer-copy">Copyright 2026 {business.name}. All rights reserved.</p>
    </div>
  </footer>

  <div class="modal-overlay" id="modal" onclick="closeModal(event)">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h3>Quick Message</h3>
        <button class="modal-close" onclick="closeModal()" aria-label="Close"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
      </div>
      <form onsubmit="event.preventDefault(); alert('Thanks. We will be in touch shortly.'); closeModal();">
        <div class="form-group"><label for="name">Name</label><input type="text" id="name" placeholder="Your name" required /></div>
        <div class="form-group"><label for="phone">Number</label><input type="tel" id="phone" placeholder="0400 000 000" required /></div>
        <div class="form-group"><label for="email">Email</label><input type="email" id="email" placeholder="you@email.com" /></div>
        <div class="form-group"><label for="message">Message</label><textarea id="message" placeholder="How can we help?"></textarea></div>
        <div class="form-row"><button type="button" class="btn btn-secondary" onclick="closeModal()">Close</button><button type="submit" class="btn btn-primary">Send</button></div>
      </form>
    </div>
  </div>

  <div class="mobile-bottom-bar">
    <div class="mobile-dropdown-wrapper" id="mobileDropdownWrapper">
      <div class="mobile-dropdown">
        <div class="mobile-dropdown-section">
          <a href="/services/" class="mobile-dropdown-title"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>Services</a>
          <div class="mobile-link-grid">
            {services.map(([serviceSlug, service]) => <a href={`/services/${serviceSlug}/`}>{service.shortTitle}</a>)}
          </div>
        </div>
        <div class="mobile-dropdown-section">
          <a href="/suburbs/" class="mobile-dropdown-title"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>Suburbs</a>
          <div class="mobile-link-grid">
            {suburbs.map(([suburbSlug, suburb]) => <a href={`/suburbs/${suburbSlug}/`}>{suburb.pageMeta.title.replace('Carpenters ', '')}</a>)}
          </div>
        </div>
        <a href="#" onclick="openModal(); return false;"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Contact Us</a>
        <a href={`tel:${business.phoneRaw}`}><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>Call Now</a>
      </div>
    </div>
    <button class="mobile-menu-toggle" id="mobileMenuToggle" onclick="toggleBottomMenu()" aria-label="Menu"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M3 12h18M3 6h18M3 18h18"/></svg></button>
  </div>
  <script src="/js/carpenter.js" defer></script>
</body>
</html>
