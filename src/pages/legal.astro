---
import Base from '../layouts/Base.astro';
import business from '../data/business.json';
---
<Base title={`Terms & Privacy | ${business.name}`} description={`Terms and privacy information for ${business.name}.`} canonicalUrl={`${business.domain}/legal/`}>
  <main>
    <section class="section service-section">
      <div class="container">
        <div class="legal-panel reveal-up">
          <h1>Terms And Privacy</h1>
          <p>This page is demo legal content. Replace it with client specific terms, privacy, address, contact and business details before launch.</p>
        </div>

        <div class="legal-grid">
          <article class="legal-panel reveal-up" id="terms">
            <h2>Terms Of Service</h2>
            <p>{business.name} provides this website as a demonstration of a local trade business website. The website does not offer real services and should not be treated as a live trading business.</p>
            <p>For a real client launch, replace this copy with the client terms, service conditions, warranty wording, quote acceptance process, cancellation policy and contact details.</p>
          </article>

          <article class="legal-panel reveal-up" id="privacy">
            <h2>Privacy Policy</h2>
            <p>{business.name} respects visitor privacy. Demo form submissions are placeholders only. A real website should explain what personal information is collected, how it is used, how long it is stored and who can access it.</p>
            <p>For production, connect the quote form to the approved client lead destination and update this policy with the correct business details.</p>
            <p>Contact: <a href={`mailto:${business.email}`}>{business.email}</a></p>
          </article>
        </div>
      </div>
    </section>
  </main>
</Base>
